{
  "screen_id": "home",
  "layout": "HomeScreenLayout",
  "navigation": {
    "tab_bar": true,
    "tab_index": 0,
    "back_button": false,
    "title": "Home"
  },
  "components": [
    {
      "type": "top_navbar",
      "id": "navbar",
      "props": { "logo": true, "actions": ["search", "messenger"] }
    },
    {
      "type": "stories_carousel",
      "id": "stories",
      "props": { "scroll": "horizontal", "item_size": "small", "show_add": true }
    },
    {
      "type": "feed_list",
      "id": "feed",
      "props": { "scroll": "vertical", "pagination": "infinite" },
      "item_template": {
        "type": "feed_card",
        "id": "feed_card_template",
        "children": [
          { "type": "card_header", "id": "card_author",  "props": { "show_follow": true } },
          { "type": "image",       "id": "card_media",   "props": { "aspect_ratio": "4:5" } },
          { "type": "action_bar",  "id": "card_actions", "props": { "actions": ["like", "comment", "share", "bookmark"] } },
          { "type": "text",        "id": "card_likes",   "style": { "font": "footnote", "weight": "semibold" } },
          { "type": "text",        "id": "card_caption", "style": { "font": "body", "lines": 2 } },
          { "type": "text",        "id": "card_time",    "style": { "font": "caption", "color": "secondary" } }
        ]
      }
    },
    {
      "type": "bottom_tab_bar",
      "id": "tab_bar",
      "props": {
        "tabs": [
          { "id": "home",    "icon": "house",  "action": "nav_home"    },
          { "id": "search",  "icon": "search", "action": "nav_search"  },
          { "id": "create",  "icon": "plus",   "action": "nav_create"  },
          { "id": "profile", "icon": "person", "action": "nav_profile" }
        ]
      }
    }
  ]
}
